# -----------------------------------------------------------------------------
# DragonPing Environment Template
# Copy this file to .env and fill in your actual values.
# -----------------------------------------------------------------------------

# --- Backend Configuration ---
ENVIRONMENT=development
DATABASE_URL=postgresql://postgres:password@db:5432/dragonping_db
DEBUG=True
API_HOST=0.0.0.0
API_PORT=8000

# --- Security ---
SECRET_KEY=dragonping-super-secret-jwt-key-2024-change-in-production
JWT_SECRET_KEY=dragonping-super-secret-jwt-key-2024-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24
AGENT_TOKEN=dragonping-agent-token-change-in-production

# --- Notifications (SMTP) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM_EMAIL=your_email@gmail.com
ADMIN_EMAIL=admin_email@domain.com
PUBLIC_DASHBOARD_URL=http://localhost:5173/public

# --- Frontend Configuration ---
VITE_API_URL=http://localhost:8000/api
