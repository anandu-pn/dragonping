# =============================================================================
# DragonPing — HPC Environment Configuration
# Copy this file and fill in your actual values before running:
#   cp .env.hpc.example .env.hpc
#   nano .env.hpc
# =============================================================================

# --- Database --------------------------------------------------------------- #
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD
POSTGRES_DB=dragonping_db
DATABASE_URL=postgresql://postgres:CHANGE_ME_STRONG_DB_PASSWORD@db:5432/dragonping_db

# --- Application ------------------------------------------------------------ #
ENVIRONMENT=production
DEBUG=False

# --- Security --------------------------------------------------------------- #
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=CHANGE_ME_REPLACE_WITH_64_CHAR_RANDOM_HEX_STRING_HERE_00000000000
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24

# --- SMTP Email Alerts (Gmail) ---------------------------------------------- #
# You need a Gmail App Password (not your normal Gmail password):
#   Google Account → Security → 2-Step Verification → App Passwords
#   Choose "Mail" + "Other (Custom name)" → copy the 16-char password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail_address@gmail.com
SMTP_PASS=xxxx_xxxx_xxxx_xxxx
SMTP_FROM_EMAIL=your_gmail_address@gmail.com

# Email address that receives DOWN/UP/CERT_EXPIRY alerts
ADMIN_EMAIL=your_alert_recipient@gmail.com

# --- Public Status Page ----------------------------------------------------- #
# Replace with the actual HPC IP and port 7190
PUBLIC_DASHBOARD_URL=http://192.168.200.75:7190/public

# --- SLA Tracking ----------------------------------------------------------- #
ENABLE_SLA=true
